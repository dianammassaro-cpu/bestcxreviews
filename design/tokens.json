{
  "name": "bestCXreviews design tokens",
  "version": "1.1",
  "color": {
    "core": {
      "ink": "#16191D",
      "deepInk": "#0E1013",
      "paper": "#F4F0E8",
      "paper2": "#EDE7DA",
      "emerald": "#0F7A52",
      "emeraldLight": "#23A877"
    },
    "neutral": {
      "slate": "#5B6168",
      "hairline": "#DAD4C8"
    },
    "chart": ["#0F7A52", "#23A877", "#3E5C7E", "#5B6168"]
  },
  "font": {
    "display": { "family": "Fraunces", "fallback": "Georgia, serif", "weights": [400, 500, 600], "use": "headlines, titles, pull quotes, bylines (italic)" },
    "text": { "family": "Hanken Grotesk", "fallback": "system-ui, sans-serif", "weights": [400, 500, 600, 700, 800], "use": "body, UI, labels, the wordmark" },
    "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap",
    "license": "SIL Open Font License"
  },
  "typeScale": {
    "display": { "size": 40, "family": "display", "weight": 600 },
    "h2": { "size": 27, "family": "display", "weight": 600 },
    "h3": { "size": 19, "family": "text", "weight": 700 },
    "body": { "size": 16, "family": "text", "weight": 400 },
    "eyebrow": { "size": 12, "family": "text", "weight": 600, "transform": "uppercase", "letterSpacing": "0.16em" }
  },
  "radius": { "sm": 8, "md": 14, "lg": 22 },
  "logo": {
    "concept": "Wordmark with the X in CX as a two-tone crossing mark (emerald + ink strokes meeting), representing the exchange between customer and company.",
    "files": {
      "primary": "design/logo-primary.svg",
      "reversed": "design/logo-reversed.svg",
      "monoInk": "design/logo-mono-ink.svg",
      "monogramDark": "design/monogram-dark.svg",
      "monogramEmerald": "design/monogram-emerald.svg"
    },
    "format": "Outlined SVG, font-independent",
    "regenerate": "python3 design/build_logos.py"
  },
  "rules": [
    "Default surface is paper with ink text.",
    "Emerald is the only accent hue in UI; use sparingly.",
    "No gradients, glows, or drop shadows on the logo.",
    "Extended palette is for charts and rare editorial only."
  ]
}
